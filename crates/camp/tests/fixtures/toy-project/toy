#!/usr/bin/env python3
"""toy — a tiny demo CLI with a real test suite.

Subcommands:
  ls    list the items, one per line

This is a fixture for the gas-camp e2e suite: a worker is asked to extend it
(e.g. add a `--json` flag) using TDD against test_toy.py.
"""
import sys

ITEMS = ["alpha", "beta", "gamma"]


def cmd_ls(args):
    # Plain listing: one item per line. Extension point for new flags.
    for item in ITEMS:
        print(item)
    return 0


def main(argv):
    if not argv or argv[0] in ("-h", "--help"):
        print("usage: toy <command> [options]")
        print("commands:")
        print("  ls    list the items")
        return 0
    cmd, rest = argv[0], argv[1:]
    if cmd == "ls":
        return cmd_ls(rest)
    print(f"toy: unknown command: {cmd}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
