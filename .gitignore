/target
.camp/

# This workspace ships a binary: the lockfile is committed for reproducible
# builds (overrides the machine-global ignore of Cargo.lock).
!Cargo.lock

# The reference container's build context is the repo root, so .dockerignore is
# what keeps target/ and .git/ out of it — it must be versioned, or every
# `docker build -f contrib/docker/Dockerfile .` ships the host's build
# artifacts (overrides the machine-global ignore of .dockerignore).
!.dockerignore

# Project Claude Code config (skill, hooks, settings) is versioned
# (overrides the machine-global ignore of .claude/); per-user local
# overrides stay out.
!.claude/
.claude/settings.local.json
# Ephemeral agent worktrees (isolation mode) — never part of the repo.
.claude/worktrees/

# Gas Camp runtime state (camp.toml is the tracked source of truth)
/ci/gc-compat/.worker-contract-happy/.camp/camp.db
/ci/gc-compat/.worker-contract-happy/.camp/camp.db-wal
/ci/gc-compat/.worker-contract-happy/.camp/camp.db-shm
/ci/gc-compat/.worker-contract-happy/.camp/campd.sock
/ci/gc-compat/.worker-contract-happy/.camp/campd.sock.lock
/ci/gc-compat/.worker-contract-happy/.camp/campd.log
/ci/gc-compat/.worker-contract-happy/.camp/runs/
/ci/gc-compat/.worker-contract-happy/.camp/sessions/
/ci/gc-compat/.worker-contract-happy/.camp/worktrees/
/ci/gc-compat/.worker-contract-happy/.camp/imports/
/ci/gc-compat/.worker-contract-happy/.camp/bin/
