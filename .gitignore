/target
.camp/

# This workspace ships a binary: the lockfile is committed for reproducible
# builds (overrides the machine-global ignore of Cargo.lock).
!Cargo.lock

# Project Claude Code config (skill, hooks, settings) is versioned
# (overrides the machine-global ignore of .claude/); per-user local
# overrides stay out.
!.claude/
.claude/settings.local.json
# Ephemeral agent worktrees (isolation mode) — never part of the repo.
.claude/worktrees/
